{
  "name": "backend",
  "version": "1.0.0",
  "description": "Express.js backend for Reliance Portal",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon --watch src --ext js --exec \"node --env-file=.env src/server.js\"",
    "start": "node --env-file=.env src/server.js",
    "server": "npm run dev",
    "build": "node scripts/check-syntax.js",
    "db:seed": "node --env-file=.env scripts/seed.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^10.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "googleapis": "^173.0.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.9.0",
    "nodemon": "^3.1.14",
    "multer": "^2.2.0"
  }
}
