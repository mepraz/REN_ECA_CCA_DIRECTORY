{
  "name": "backend",
  "version": "1.0.0",
  "description": "Express.js backend for Reliance Portal",
  "main": "dist/server.js",
  "scripts": {
    "dev": "node --env-file=.env --import tsx --watch src/server.ts",
    "server": "npm run dev",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:seed": "tsx --env-file=.env scripts/seed.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "googleapis": "^173.0.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.9.0",
    "multer": "^2.2.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.17.9",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2"
  }
}
